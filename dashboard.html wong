<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventory Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="h-screen flex bg-[#f5e0c3] dark:bg-gray-900 text-gray-800 dark:text-gray-200">

<div class="flex flex-1 flex-col h-screen overflow-hidden">

  <!-- HEADER -->
  <div class="flex justify-between items-center px-6 py-4 bg-[#f5e0c3] dark:bg-gray-800 shadow">
    <div class="flex items-center space-x-2">
      <button class="lg:hidden px-2 py-1 bg-blue-800 dark:bg-blue-600 text-white rounded" onclick="toggleSidebar()">☰</button>
      <h2 class="text-xl font-bold text-blue-800 dark:text-blue-400">Dashboard</h2>
    </div>
    <div class="flex items-center space-x-4">
      <span id="utcClock" class="font-mono text-gray-700 dark:text-gray-300"></span>
      <button class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700" onclick="logout()">Logout</button>
    </div>
  </div>

  <div class="flex flex-1 overflow-hidden">
    <!-- SIDEBAR -->
    <div id="sidebar" class="w-64 bg-[#e0c5a2] dark:bg-gray-900 p-4 overflow-y-auto hidden lg:block rounded-r">
      <ul class="space-y-2 text-gray-800 dark:text-gray-200">
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('overview')">Overview</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('pos')">POS</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('inventory')">Inventory</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('stock')">Stock</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('users')">Users</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('reports')">Reports</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="showSection('credits')">Customer Credits</li>
        <li class="hover:bg-blue-100 dark:hover:bg-blue-800 cursor-pointer p-2 rounded" onclick="toggleTheme()">Toggle Dark/Light</li>
      </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="flex-1 overflow-y-auto p-6 space-y-6">

      <!-- OVERVIEW SECTION -->
      <div id="overviewSection">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <div class="bg-[#f5deb3] dark:bg-gray-800 rounded shadow p-4 cursor-pointer hover:shadow-lg">
            <h3 class="font-semibold">Today's Sales</h3>
            <p class="text-2xl font-bold" id="todaySales">$0</p>
          </div>
          <div class="bg-[#f5deb3] dark:bg-gray-800 rounded shadow p-4 cursor-pointer hover:shadow-lg">
            <h3 class="font-semibold">Total Revenue</h3>
            <p class="text-2xl font-bold" id="totalRevenue">$0</p>
          </div>
          <div class="bg-[#f5deb3] dark:bg-gray-800 rounded shadow p-4 cursor-pointer hover:shadow-lg">
            <h3 class="font-semibold">Total Products</h3>
            <p class="text-2xl font-bold" id="totalProducts">0</p>
          </div>
          <div class="bg-[#f5deb3] dark:bg-gray-800 rounded shadow p-4 cursor-pointer hover:shadow-lg">
            <h3 class="font-semibold">Customer Credits</h3>
            <p class="text-2xl font-bold" id="customerCredits">$0</p>
          </div>
        </div>

        <div class="bg-[#f5deb3] dark:bg-gray-800 rounded shadow p-4">
          <canvas id="salesChart"></canvas>
        </div>
      </div>

      <!-- POS SECTION -->
      <div id="posSection" class="hidden">
        <h3 class="text-lg font-bold mb-2">Point of Sale (POS)</h3>
        <input type="text" placeholder="Search products..." id="posSearch" class="mb-2 p-2 border rounded w-full" oninput="renderPOS()">
        <div id="posGrid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
        <div class="mt-4">
          <h4 class="font-bold">Cart</h4>
          <ul id="cartList" class="list-disc pl-5"></ul>
          <button class="mt-2 px-3 py-1 bg-green-600 text-white rounded" onclick="checkout()">Checkout</button>
        </div>
      </div>

      <!-- INVENTORY SECTION -->
      <div id="inventorySection" class="hidden">
        <h3 class="text-lg font-bold mb-2">Inventory Management</h3>
        <div class="mb-4">
          <input type="text" id="newProductName" placeholder="Product Name" class="p-2 border rounded mr-2">
          <input type="number" id="newProductStock" placeholder="Stock" class="p-2 border rounded mr-2" min="0">
          <input type="number" id="newProductPrice" placeholder="Price" class="p-2 border rounded mr-2" min="0">
          <button class="px-3 py-1 bg-blue-600 text-white rounded" onclick="addProduct()">Add Product</button>
        </div>
        <div id="inventoryGrid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
      </div>

      <div id="stockSection" class="hidden"><h3>Stock Section (Mock)</h3></div>
      <div id="usersSection" class="hidden"><h3>Users Section (Mock)</h3></div>
      <div id="reportsSection" class="hidden"><h3>Reports Section (Mock)</h3></div>
      <div id="creditsSection" class="hidden"><h3>Customer Credits (Mock)</h3></div>

    </div>
  </div>
</div>

<script>
// Auto login check
if(!localStorage.getItem("loggedInUser")) window.location.href="login.html";

// UTC Clock
setInterval(()=>{
  const d=new Date();
  const utc=d.toUTCString().split(' ')[4];
  document.getElementById('utcClock').innerText=utc;
},1000);

// Sidebar toggle
function toggleSidebar(){ document.getElementById('sidebar').classList.toggle('hidden'); }

// Dark/Light mode
function toggleTheme(){ document.documentElement.classList.toggle('dark'); }

// Logout
function logout(){
  localStorage.removeItem('loggedInUser');
  window.location.href='login.html';
}

// Section toggle
function showSection(section){
  const sections=['overview','pos','inventory','stock','users','reports','credits'];
  sections.forEach(s=>document.getElementById(s+'Section').classList.add('hidden'));
  document.getElementById(section+'Section').classList.remove('hidden');
}

// INITIAL DATA
let products = [
  {name:'Product A', stock:20, price:50},
  {name:'Product B', stock:5, price:30},
  {name:'Product C', stock:10, price:20},
];
let cart=[];

// RENDER POS
function renderPOS(){
  const search = document.getElementById('posSearch').value.toLowerCase();
  const grid = document.getElementById('posGrid');
  grid.innerHTML='';
  products.filter(p=>p.name.toLowerCase().includes(search)).forEach(p=>{
    grid.innerHTML += `
      <div class="bg-[#f5deb3] dark:bg-gray-800 p-2 rounded shadow">
        <p class="font-semibold">${p.name}</p>
        <p>Stock: ${p.stock}</p>
        <p>Price: $${p.price}</p>
        <div class="flex space-x-1 mt-1">
          <input type="number" min="1" max="${p.stock}" value="1" id="qty-${p.name}" class="w-16 p-1 border rounded">
          <button class="px-2 py-1 bg-green-600 text-white rounded" onclick="addToCart('${p.name}')">Add</button>
        </div>
      </div>
    `;
  });
}

// ADD TO CART
function addToCart(name){
  const qty = parseInt(document.getElementById(`qty-${name}`).value);
  const prod = products.find(p=>p.name===name);
  if(qty>prod.stock){ alert('Not enough stock'); return; }
  const cartItem = cart.find(c=>c.name===name);
  if(cartItem){ cartItem.qty+=qty; } else { cart.push({name, qty, price:prod.price}); }
  renderCart();
}

// RENDER CART
function renderCart(){
  document.getElementById('cartList').innerHTML = cart.map(c=>`${c.name} x ${c.qty} ($${c.price*c.qty}) <button onclick="removeFromCart('${c.name}')" class="text-red-500">Remove</button>`).join('<br>');
}

// REMOVE FROM CART
function removeFromCart(name){
  cart = cart.filter(c=>c.name!==name);
  renderCart();
}

// CHECKOUT
let todaySales=0, totalRevenue=0;
function checkout(){
  cart.forEach(item=>{
    const prod = products.find(p=>p.name===item.name);
    prod.stock -= item.qty;
    todaySales+=item.qty*item.price;
    totalRevenue+=item.qty*item.price;
  });
  cart=[];
  renderCart();
  renderPOS();
  renderInventory();
  updateOverview();
}

// INVENTORY CRUD
function renderInventory(){
  const grid=document.getElementById('inventoryGrid');
  grid.innerHTML='';
  products.forEach(p=>{
    grid.innerHTML += `
      <div class="bg-[#f5deb3] dark:bg-gray-800 p-4 rounded shadow">
        <p class="font-semibold">${p.name}</p>
        <p>Stock: ${p.stock} ${p.stock<5?'<span class="text-red-500 font-bold">Low</span>':''}</p>
        <p>Price: $${p.price}</p>
        <div class="flex space-x-2 mt-2">
          <button class="px-2 py-1 bg-green-600 text-white rounded text-sm" onclick="editProduct('${p.name}')">Edit</button>
          <button class="px-2 py-1 bg-red-600 text-white rounded text-sm" onclick="deleteProduct('${p.name}')">Delete</button>
        </div>
      </div>
    `;
  });
}

// ADD PRODUCT
function addProduct(){
  const name=document.getElementById('newProductName').value;
  const stock=parseInt(document.getElementById('newProductStock').value);
  const price=parseFloat(document.getElementById('newProductPrice').value);
  if(!name||stock<0||price<0){ alert('Invalid input'); return; }
  products.push({name, stock, price});
  document.getElementById('newProductName').value='';
  document.getElementById('newProductStock').value='';
  document.getElementById('newProductPrice').value='';
  renderPOS();
  renderInventory();
  updateOverview();
}

// EDIT PRODUCT
function editProduct(name){
  const prod=products.find(p=>p.name===name);
  const newStock=parseInt(prompt('Enter new stock', prod.stock));
  const newPrice=parseFloat(prompt('Enter new price', prod.price));
  if(!isNaN(newStock)) prod.stock=newStock;
  if(!isNaN(newPrice)) prod.price=newPrice;
  renderPOS();
  renderInventory();
  updateOverview();
}

// DELETE PRODUCT
function deleteProduct(name){
  products=products.filter(p=>p.name!==name);
  renderPOS();
  renderInventory();
  updateOverview();
}

// OVERVIEW
function updateOverview(){
  document.getElementById('todaySales').innerText='$'+todaySales;
  document.getElementById('totalRevenue').innerText='$'+totalRevenue;
  document.getElementById('totalProducts').innerText=products.length;
  document.getElementById('customerCredits').innerText='$0';
}
updateOverview();
renderPOS();
renderInventory();

// Chart
const ctx=document.getElementById('salesChart');
new Chart(ctx,{
  type:'bar',
  data:{
    labels:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
    datasets:[{ label:'Sales', data:[120,150,100,170,200,80,130], backgroundColor:'#3b82f6' }]
  },
  options:{ responsive:true, plugins:{legend:{display:false}} }
});
</script>

</body>
</html>
