# ── Django ─────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database engine: mysql | mssql ──────────────────────────────
DB_ENGINE=mysql

# ── MySQL / MariaDB (XAMPP) ─────────────────────────────────
DB_NAME=haneuscafedb
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ── SQL Server (SSMS 19) — uncomment when DB_ENGINE=mssql ────────────
# DB_NAME=haneuscafedb
# DB_USER=ProjectSuico
# DB_PASSWORD=9999
# DB_HOST=localhost
# DB_PORT=1433
# DB_MSSQL_DRIVER=ODBC Driver 17 for SQL Server
# DB_WINDOWS_AUTH=False     # set True to use Windows Authentication instead

# ── Frontend (for reference) ──────────────────────────────
API_BASE_URL=http://localhost:8000
