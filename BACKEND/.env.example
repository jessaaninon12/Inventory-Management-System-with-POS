# Django settings
DJANGO_SECRET_KEY="change-this-to-a-random-secret-key"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database engine selection: mysql | mssql
DB_ENGINE=mysql

# Database credentials (used by mysql and mssql only)
DB_NAME=haneus_cafe_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# SQL Server specific (only when DB_ENGINE=mssql)
# DB_PORT=1433
# DB_MSSQL_DRIVER=ODBC Driver 17 for SQL Server
